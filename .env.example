# Copy this file to ".env" and fill in your keys.

# Brain (free key from https://aistudio.google.com -> "Get API key")
GEMINI_API_KEY=

# TTS — Chatterbox (default on Vast) needs no key. Only fill these if you switch
# Arabic to paid ElevenLabs, or use Cartesia.
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# Your TikTok handle (for reading the live chat)
TIKTOK_USERNAME=blingramcreators

# Optional: free EulerStream key if TikTokLive asks for one
EULERSTREAM_API_KEY=

# Streaming directly to TikTok via RTMP (Vast.ai / OBS Custom service).
# Get these from TikTok LIVE -> "Go LIVE" -> stream via third-party software.
TIKTOK_SERVER_URL=rtmp://push.tiktok.com/...
TIKTOK_STREAM_KEY=your_tiktok_stream_key
