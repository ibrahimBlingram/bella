# Copy this file to ".env" and fill in your keys.

# Brain (free key from https://aistudio.google.com -> "Get API key")
GEMINI_API_KEY=

# TTS — fill the ONE you're testing with
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# Your TikTok handle (for the full run, not needed for test_brain/voice/chat)
TIKTOK_USERNAME=

# Optional: free EulerStream key if TikTokLive asks for one
EULERSTREAM_API_KEY=
